{
  "name": "@railswitch/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src/",
    "migration:generate": "npx drizzle-kit generate",
    "migration:run": "npx drizzle-kit migrate", 
    "migration:push": "npx drizzle-kit push"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "nanoid": "^5.1.16",
    "pg": "^8.11.0",
    "xstate": "^5.0.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/express": "^4.17.25",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
